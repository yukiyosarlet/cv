{% extends 'base.html.twig' %}

{% block title %}Yukiyo Sarlet - Ervaring{% endblock %}

{% block body %}
<div class="container container-single">
    <section class="content content-full">
        <h1 class="page-title">Werkervaring</h1>

        <div class="timeline">
            {% for job in ervaringen %}
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
                    <div class="timeline-card">
                        <span class="periode">{{ job.periode }}</span>
                        <h3>{{ job.functie }}</h3>
                        <p class="bedrijf">{{ job.bedrijf }}</p>
                        <ul>
                            {% for taak in job.taken %}
                                <li>{{ taak }}</li>
                            {% endfor %}
                        </ul>
                        <div class="talen-tags">
                            {% for taal in job.talen %}
                                <span class="skill-tag">{{ taal }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>
</div>
{% endblock %}
